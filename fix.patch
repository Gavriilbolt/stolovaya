+                (SELECT COUNT(*) FROM orders) AS total_orders,
+                (SELECT COUNT(*) FROM staff) AS total_staff
+        `);
+
+        const recentOrders = await db.all(`
+            SELECT o.*, mi.name AS menu_item_name, s.name AS staff_name
