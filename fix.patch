+<!DOCTYPE html>
+<html lang="ru">
+<head>
+    <meta charset="UTF-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1.0">
+    <title><%= title %></title>
+    <link rel="stylesheet" href="/css/style.css">
+</head>
+<body>
+<header class="header">
+    <div class="container">
+        <nav class="navbar">
+            <a href="/" class="logo">🍽️ Университетская столовая</a>
+            <ul class="nav-links">
+                <li><a href="/">Дашборд</a></li>
+                <li><a href="/menu" class="active">Меню</a></li>
+                <li><a href="/orders">Заказы</a></li>
+                <li><a href="/staff">Персонал</a></li>
+            </ul>
+        </nav>
+    </div>
+</header>
+
+<main class="main">
+    <div class="container">
+        <div class="page-header">
+            <h1>Меню столовой</h1>
+            <button class="btn btn-primary" onclick="toggleForm()">+ Добавить блюдо</button>
+        </div>
+
+        <div id="addForm" class="form-container" style="display:none;">
+            <h3>Добавить новое блюдо</h3>
+            <form action="/menu" method="POST">
+                <div class="form-group">
+                    <label for="category_id">Категория:</label>
+                    <select id="category_id" name="category_id" required>
+                        <option value="">Выберите категорию</option>
+                        <% categories.forEach(category => { %>
+                            <option value="<%= category.id %>"><%= category.name %></option>
+                        <% }) %>
+                    </select>
+                </div>
+                <div class="form-group">
+                    <label for="name">Название блюда:</label>
+                    <input type="text" id="name" name="name" required>
+                </div>
+                <div class="form-group">
+                    <label for="description">Описание:</label>
+                    <textarea id="description" name="description" rows="3"></textarea>
+                </div>
+                <div class="form-group">
+                    <label for="price">Цена (руб.):</label>
+                    <input type="number" id="price" name="price" step="0.01" min="0" required>
+                </div>
+                <div class="form-group">
+                    <label for="calories">Калорийность (ккал):</label>
+                    <input type="number" id="calories" name="calories" min="0">
+                </div>
+                <div class="form-group">
+                    <label for="is_available">Доступность:</label>
+                    <select id="is_available" name="is_available">
+                        <option value="1">Доступно</option>
+                        <option value="0">Нет в наличии</option>
+                    </select>
+                </div>
+                <button type="submit" class="btn btn-primary">Добавить</button>
+                <button type="button" class="btn btn-secondary" onclick="toggleForm()">Отмена</button>
+            </form>
+        </div>
+
+        <div class="table-container">
+            <% if (menuItems.length > 0) { %>
+                <table class="data-table">
+                    <thead>
+                    <tr>
+                        <th>Блюдо</th>
+                        <th>Категория</th>
+                        <th>Цена</th>
+                        <th>Ккал</th>
+                        <th>Статус</th>
+                        <th>Действия</th>
+                    </tr>
+                    </thead>
+                    <tbody>
+                    <% menuItems.forEach(item => { %>
+                        <tr>
+                            <td>
+                                <strong><%= item.name %></strong>
+                                <% if (item.description) { %>
+                                    <br><small><%= item.description %></small>
+                                <% } %>
+                            </td>
+                            <td><%= item.category_name %></td>
+                            <td><%= Number(item.price || 0).toFixed(2) %> руб.</td>
+                            <td><%= item.calories || '—' %></td>
+                            <td>
+                                <span class="status-badge <%= item.is_available ? 'status-active' : 'status-inactive' %>">
+                                    <%= item.is_available ? 'Доступно' : 'Нет в наличии' %>
+                                </span>
+                            </td>
+                            <td>
+                                <div class="action-buttons">
+                                    <a href="/menu/edit/<%= item.id %>" class="btn btn-small btn-primary">✏️</a>
+                                    <form action="/menu/delete/<%= item.id %>" method="POST" style="display:inline;">
+                                        <button type="submit" class="btn btn-small btn-danger" onclick="return confirm('Удалить это блюдо?')">🗑️</button>
+                                    </form>
+                                </div>
+                            </td>
+                        </tr>
+                    <% }) %>
+                    </tbody>
+                </table>
+            <% } else { %>
+                <div class="empty-state"><p>Меню пока пустое</p></div>
+            <% } %>
+        </div>
+    </div>
+</main>
+
+<footer class="footer">
+    <div class="container"><p>&copy; 2026 Университетская столовая</p></div>
+</footer>
+
+<script>
+    function toggleForm() {
+        const form = document.getElementById('addForm');
+        form.style.display = form.style.display === 'none' ? 'block' : 'none';
+    }
+</script>
+</body>
+</html>
