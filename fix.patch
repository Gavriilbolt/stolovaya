+    <title><%= title %></title>
+    <link rel="stylesheet" href="/css/style.css">
+</head>
+<body>
+    <header class="header">
+        <div class="container">
+            <nav class="navbar">
+                <a href="/" class="logo">🍽️ Университетская столовая</a>
+                <ul class="nav-links">
+                    <li><a href="/" class="active">Дашборд</a></li>
+                    <li><a href="/menu">Меню</a></li>
+                    <li><a href="/orders">Заказы</a></li>
+                    <li><a href="/staff">Персонал</a></li>
+                </ul>
+            </nav>
+        </div>
+    </header>
+
+    <main class="main">
+        <div class="container">
+            <h1>Панель управления столовой</h1>
+
+            <div class="stats-grid">
+                <div class="stat-card">
+                    <h3>Блюд в меню</h3>
+                    <div class="stat-number"><%= stats.total_menu_items %></div>
+                </div>
+                <div class="stat-card warning">
+                    <h3>Доступно сегодня</h3>
+                    <div class="stat-number"><%= stats.available_menu_items %></div>
+                </div>
+                <div class="stat-card">
+                    <h3>Всего заказов</h3>
+                    <div class="stat-number"><%= stats.total_orders %></div>
+                </div>
+                <div class="stat-card">
+                    <h3>Сотрудников</h3>
+                    <div class="stat-number"><%= stats.total_staff %></div>
+                </div>
+            </div>
+
+            <div class="recent-repairs">
+                <h2>Последние заказы</h2>
+                <% if (recentOrders.length > 0) { %>
+                    <div class="repairs-list">
+                        <% recentOrders.forEach(order => { %>
+                            <div class="repair-item">
+                                <div class="repair-header">
+                                    <strong><%= order.menu_item_name || 'Блюдо удалено' %></strong>
+                                    <span class="repair-date"><%= new Date(order.order_date).toLocaleDateString('ru-RU') %></span>
+                                </div>
+                                <div class="repair-details">
+                                    <p><strong>Тип клиента:</strong>
+                                        <%= order.customer_type === 'student' ? 'Студент' : order.customer_type === 'teacher' ? 'Преподаватель' : 'Гость' %>
+                                    </p>
+                                    <p><strong>Количество:</strong> <%= order.quantity %> порц.</p>
+                                    <p><strong>Сумма:</strong> <%= Number(order.total_price || 0).toFixed(2) %> руб.</p>
+                                    <p><strong>Выдал:</strong> <%= order.staff_name || 'Не назначено' %></p>
+                                </div>
+                            </div>
+                        <% }) %>
+                    </div>
+                <% } else { %>
+                    <p>Заказов пока нет</p>
+                <% } %>
+                <a href="/orders" class="btn btn-primary">Все заказы</a>
+            </div>
+        </div>
+    </main>
+
+    <footer class="footer">
+        <div class="container">
+            <p>&copy; 2026 Университетская столовая</p>
+        </div>
+    </footer>
+</body>
+</html>
