+            <form action="/menu/edit/<%= menuItem.id %>" method="POST">
+                <div class="form-group">
+                    <label for="category_id">Категория:</label>
+                    <select id="category_id" name="category_id" required>
+                        <% categories.forEach(category => { %>
+                            <option value="<%= category.id %>" <%= menuItem.category_id == category.id ? 'selected' : '' %>>
+                                <%= category.name %>
+                            </option>
+                        <% }) %>
+                    </select>
+                </div>
+                <div class="form-group">
+                    <label for="name">Название блюда:</label>
+                    <input type="text" id="name" name="name" value="<%= menuItem.name %>" required>
+                </div>
+                <div class="form-group">
+                    <label for="description">Описание:</label>
+                    <textarea id="description" name="description" rows="3"><%= menuItem.description || '' %></textarea>
+                </div>
+                <div class="form-group">
+                    <label for="price">Цена (руб.):</label>
+                    <input type="number" id="price" name="price" step="0.01" min="0" value="<%= menuItem.price %>" required>
+                </div>
+                <div class="form-group">
+                    <label for="calories">Калорийность (ккал):</label>
+                    <input type="number" id="calories" name="calories" min="0" value="<%= menuItem.calories || '' %>">
+                </div>
+                <div class="form-group">
+                    <label for="is_available">Доступность:</label>
+                    <select id="is_available" name="is_available">
+                        <option value="1" <%= menuItem.is_available ? 'selected' : '' %>>Доступно</option>
+                        <option value="0" <%= !menuItem.is_available ? 'selected' : '' %>>Нет в наличии</option>
+                    </select>
+                </div>
+                <div class="form-actions">
+                    <button type="submit" class="btn btn-primary">Сохранить изменения</button>
+                    <a href="/menu" class="btn btn-secondary">Отмена</a>
+                </div>
+            </form>
+        </div>
+    </div>
+</main>
+
+<footer class="footer">
+    <div class="container"><p>&copy; 2026 Университетская столовая</p></div>
+</footer>
+</body>
+</html>
