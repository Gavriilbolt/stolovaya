<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Node.js App</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="header">
        <div class="container">
            <nav class="navbar">
                <a href="/" class="logo">NodeApp</a>
                <ul class="nav-links">
                    <li><a href="/">Главная</a></li>
                    <li><a href="/login">Вход</a></li>
                    <li><a href="/register">Регистрация</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="main">
        <div class="container">
            <div class="error-container">
                <h1>Ошибка</h1>
                <p class="error-message"><%= error %></p>
                <a href="/" class="btn btn-primary">Вернуться на главную</a>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 Node.js Application</p>
        </div>
    </footer>
</body>
</html>