<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="header">
        <div class="container">
            <nav class="navbar">
                <a href="/" class="logo">📊 Учет ремонта</a>
                <ul class="nav-links">
                    <li><a href="/">Дашборд</a></li>
                    <li><a href="/equipment">Оборудование</a></li>
                    <li><a href="/repairs" class="active">Ремонты</a></li>
                    <li><a href="/employees">Сотрудники</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="main">
        <div class="container">
            <div class="page-header">
    <h1>Ремонты оборудования</h1>
    <div class="header-actions">
        <button class="btn btn-primary" onclick="toggleForm()">+ Добавить ремонт</button>
        <a href="/reports/repairs" class="btn btn-success">📊 Выгрузить PDF отчет</a>
    </div>
</div>

            <!-- Форма добавления ремонта -->
            <div id="addForm" class="form-container" style="display: none;">
                <h3>Добавить новый ремонт</h3>
                <form action="/repairs" method="POST">
                    <div class="form-group">
                        <label for="equipment_id">Оборудование:</label>
                        <select id="equipment_id" name="equipment_id" required>
                            <option value="">Выберите оборудование</option>
                            <% equipment.forEach(item => { %>
                                <option value="<%= item.id %>">
                                    <%= item.inventory_number %> - <%= item.name %> (<%= item.type_name %>)
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="employee_id">Исполнитель:</label>
                        <select id="employee_id" name="employee_id" required>
                            <option value="">Выберите сотрудника</option>
                            <% employees.forEach(emp => { %>
                                <option value="<%= emp.id %>"><%= emp.name %> - <%= emp.position %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="repair_date">Дата ремонта:</label>
                        <input type="date" id="repair_date" name="repair_date" required value="<%= new Date().toISOString().split('T')[0] %>">
                    </div>
                    <div class="form-group">
                        <label for="problem_description">Описание проблемы:</label>
                        <textarea id="problem_description" name="problem_description" rows="3" required></textarea>
                    </div>
                    <div class="form-group">
                        <label for="solution">Выполненные работы:</label>
                        <textarea id="solution" name="solution" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="repair_cost">Стоимость ремонта (руб.):</label>
                        <input type="number" id="repair_cost" name="repair_cost" step="0.01" min="0">
                    </div>
                    <button type="submit" class="btn btn-primary">Добавить ремонт</button>
                    <button type="button" class="btn btn-secondary" onclick="toggleForm()">Отмена</button>
                </form>
            </div>

            <!-- Список ремонтов -->
            <div class="repairs-list">
                <% if (repairs.length > 0) { %>
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Дата</th>
                                    <th>Оборудование</th>
                                    <th>Проблема</th>
                                    <th>Исполнитель</th>
                                    <th>Решение</th>
                                    <th>Стоимость</th>
                                    <th>Статус</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% repairs.forEach(repair => { %>
                                    <tr>
                                        <td><%= new Date(repair.repair_date).toLocaleDateString('ru-RU') %></td>
                                        <td>
                                            <strong><%= repair.inventory_number %></strong><br>
                                            <%= repair.equipment_name %>
                                        </td>
                                        <td><%= repair.problem_description %></td>
                                        <td><%= repair.employee_name %></td>
                                        <td><%= repair.solution || '—' %></td>
                                        <td>
                                            <% if (repair.repair_cost > 0) { %>
                                                <strong><%= repair.repair_cost %> руб.</strong>
                                            <% } else { %>
                                                —
                                            <% } %>
                                        </td>
                                        <td>
                                            <span class="status-badge <%= repair.status === 'completed' ? 'status-active' : repair.status === 'in_progress' ? 'status-repair' : 'status-inactive' %>">
                                                <%= repair.status === 'completed' ? 'Завершен' : repair.status === 'in_progress' ? 'В работе' : 'Отменен' %>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="action-buttons">
                                                <a href="/repairs/edit/<%= repair.id %>" class="btn btn-small btn-primary">✏️</a>
                                                <form action="/repairs/delete/<%= repair.id %>" method="POST" style="display: inline;">
                                                    <button type="submit" class="btn btn-small btn-danger" onclick="return confirm('Удалить этот ремонт?')">🗑️</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <p>Ремонты не найдены</p>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 Система учета ремонта оборудования</p>
        </div>
    </footer>

    <script>
        function toggleForm() {
            const form = document.getElementById('addForm');
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }
    </script>
</body>
</html>