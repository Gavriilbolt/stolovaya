<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header class="header">
    <div class="container">
        <nav class="navbar">
            <a href="/" class="logo">🍽️ Университетская столовая</a>
            <ul class="nav-links">
                <li><a href="/">Дашборд</a></li>
                <li><a href="/menu">Меню</a></li>
                <li><a href="/orders" class="active">Заказы</a></li>
                <li><a href="/staff">Персонал</a></li>
            </ul>
        </nav>
    </div>
</header>

<main class="main">
    <div class="container">
        <div class="page-header">
            <h1>Редактирование заказа</h1>
            <a href="/orders" class="btn btn-secondary">← Назад к заказам</a>
        </div>

        <div class="form-container">
            <form action="/orders/edit/<%= order.id %>" method="POST">
                <div class="form-group">
                    <label for="menu_item_id">Блюдо:</label>
                    <select id="menu_item_id" name="menu_item_id" required>
                        <% menuItems.forEach(item => { %>
                            <option value="<%= item.id %>" <%= order.menu_item_id == item.id ? 'selected' : '' %>>
                                <%= item.name %> — <%= Number(item.price || 0).toFixed(2) %> руб.
                            </option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label for="staff_id">Сотрудник на выдаче:</label>
                    <select id="staff_id" name="staff_id">
                        <option value="" <%= !order.staff_id ? 'selected' : '' %>>Не назначать</option>
                        <% staff.forEach(member => { %>
                            <option value="<%= member.id %>" <%= order.staff_id == member.id ? 'selected' : '' %>>
                                <%= member.name %> — <%= member.position %>
                            </option>
                        <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label for="order_date">Дата заказа:</label>
                    <input type="date" id="order_date" name="order_date" value="<%= order.order_date %>" required>
                </div>
                <div class="form-group">
                    <label for="customer_type">Категория посетителя:</label>
                    <select id="customer_type" name="customer_type" required>
                        <option value="student" <%= order.customer_type === 'student' ? 'selected' : '' %>>Студент</option>
                        <option value="teacher" <%= order.customer_type === 'teacher' ? 'selected' : '' %>>Преподаватель</option>
                        <option value="guest" <%= order.customer_type === 'guest' ? 'selected' : '' %>>Гость</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="quantity">Количество порций:</label>
                    <input type="number" id="quantity" name="quantity" min="1" value="<%= order.quantity %>" required>
                </div>
                <div class="form-group">
                    <label for="status">Статус:</label>
                    <select id="status" name="status">
                        <option value="new" <%= order.status === 'new' ? 'selected' : '' %>>Новый</option>
                        <option value="preparing" <%= order.status === 'preparing' ? 'selected' : '' %>>Готовится</option>
                        <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Выдан</option>
                        <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Отменен</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="comment">Комментарий:</label>
                    <textarea id="comment" name="comment" rows="3"><%= order.comment || '' %></textarea>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Сохранить изменения</button>
                    <a href="/orders" class="btn btn-secondary">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</main>

<footer class="footer">
    <div class="container"><p>&copy; 2026 Университетская столовая</p></div>
</footer>
</body>
</html>
