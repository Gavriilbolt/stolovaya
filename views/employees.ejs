<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="header">
        <div class="container">
            <nav class="navbar">
                <a href="/" class="logo">📊 Учет ремонта</a>
                <ul class="nav-links">
                    <li><a href="/">Дашборд</a></li>
                    <li><a href="/equipment">Оборудование</a></li>
                    <li><a href="/repairs">Ремонты</a></li>
                    <li><a href="/employees" class="active">Сотрудники</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="main">
        <div class="container">
            <div class="page-header">
                <h1>Сотрудники</h1>
                <button class="btn btn-primary" onclick="toggleForm()">+ Добавить сотрудника</button>
            </div>

            <!-- Форма добавления сотрудника -->
            <div id="addForm" class="form-container" style="display: none;">
                <h3>Добавить нового сотрудника</h3>
                <form action="/employees" method="POST">
                    <div class="form-group">
                        <label for="name">ФИО:</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="position">Должность:</label>
                        <input type="text" id="position" name="position" required>
                    </div>
                    <div class="form-group">
                        <label for="department">Отдел:</label>
                        <input type="text" id="department" name="department" required>
                    </div>
                    <div class="form-group">
                        <label for="phone">Телефон:</label>
                        <input type="tel" id="phone" name="phone">
                    </div>
                    <div class="form-group">
                        <label for="email">Email:</label>
                        <input type="email" id="email" name="email">
                    </div>
                    <button type="submit" class="btn btn-primary">Добавить</button>
                    <button type="button" class="btn btn-secondary" onclick="toggleForm()">Отмена</button>
                </form>
            </div>

            <!-- Список сотрудников -->
            <div class="employees-list">
                <% if (employees.length > 0) { %>
                    <div class="employees-grid">
                        <% employees.forEach(employee => { %>
                            <div class="employee-card">
                                <div class="employee-header">
                                    <h3><%= employee.name %></h3>
                                    <div class="action-buttons">
                                        <a href="/employees/edit/<%= employee.id %>" class="btn btn-small btn-primary">✏️</a>
                                        <form action="/employees/delete/<%= employee.id %>" method="POST" style="display: inline;">
                                            <button type="submit" class="btn btn-small btn-danger" onclick="return confirm('Удалить этого сотрудника?')">🗑️</button>
                                        </form>
                                    </div>
                                </div>
                                <div class="employee-details">
                                    <p><strong>Должность:</strong> <%= employee.position %></p>
                                    <p><strong>Отдел:</strong> <%= employee.department %></p>
                                    <% if (employee.phone) { %>
                                        <p><strong>Телефон:</strong> <%= employee.phone %></p>
                                    <% } %>
                                    <% if (employee.email) { %>
                                        <p><strong>Email:</strong> <%= employee.email %></p>
                                    <% } %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <p>Сотрудники не найдены</p>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 Система учета ремонта оборудования</p>
        </div>
    </footer>

    <script>
        function toggleForm() {
            const form = document.getElementById('addForm');
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }
    </script>
</body>
</html>