<%- include('partials/header', { title, active: 'orders' }) %>
<div class="page-header">
    <h1>Заказы столовой</h1>
    <div class="header-actions">
        <button class="btn btn-primary" onclick="toggleForm()">+ Новый заказ</button>
        <a href="/reports/orders" class="btn btn-success">📊 PDF-отчёт</a>
    </div>
</div>

<div id="addForm" class="form-container" style="display:none;">
    <h3>Оформить заказ</h3>
    <form action="/orders" method="POST" id="createOrderForm" data-download-receipt="1">
        <div class="form-group">
            <label>Позиции заказа:</label>
            <div id="orderItemsContainer">
                <div class="order-item-row">
                    <select name="items[0][menu_item_id]" required>
                        <option value="">Выберите блюдо</option>
                        <% menuItems.forEach(item => { %>
                            <option value="<%= item.id %>"><%= item.name %> — <%= Number(item.price || 0).toFixed(2) %> руб.</option>
                        <% }) %>
                    </select>
                    <input type="number" name="items[0][quantity]" min="1" value="1" required class="order-item-qty">
                    <button type="button" class="btn btn-small btn-danger order-item-remove" title="Убрать">✖</button>
                </div>
            </div>
            <button type="button" class="btn btn-secondary" id="addOrderItemBtn">+ Добавить блюдо</button>
        </div>
        <div class="form-group">
            <label for="staff_id">Сотрудник на выдаче:</label>
            <select id="staff_id" name="staff_id">
                <option value="">Не назначать</option>
                <% staff.forEach(member => { %>
                    <option value="<%= member.id %>"><%= member.name %> — <%= member.position %></option>
                <% }) %>
            </select>
        </div>
        <div class="form-group">
            <label for="order_date">Дата заказа:</label>
            <input type="date" id="order_date" name="order_date" required value="<%= new Date().toISOString().split('T')[0] %>">
        </div>
        <div class="form-group">
            <label for="customer_type">Категория посетителя:</label>
            <select id="customer_type" name="customer_type" required>
                <option value="student">Студент</option>
                <option value="teacher">Преподаватель</option>
                <option value="guest">Гость</option>
            </select>
        </div>
        <div class="form-group">
            <label for="status">Статус:</label>
            <select id="status" name="status">
                <option value="new">Новый</option>
                <option value="preparing">Готовится</option>
                <option value="completed">Выдан</option>
                <option value="cancelled">Отменен</option>
            </select>
        </div>
        <div class="form-group">
            <label for="comment">Комментарий:</label>
            <textarea id="comment" name="comment" rows="2"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Сохранить и скачать чек</button>
        <button type="button" class="btn btn-secondary" onclick="toggleForm()">Отмена</button>
    </form>
</div>

<% if (orders.length > 0) { %>
    <div class="table-container">
        <table class="data-table">
            <thead>
            <tr>
                <th>Дата</th>
                <th>Блюда</th>
                <th>Клиент</th>
                <th>Порции</th>
                <th>Сумма</th>
                <th>Сотрудник</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
            </thead>
            <tbody>
            <% orders.forEach(order => { %>
                <tr>
                    <td><%= new Date(order.order_date).toLocaleDateString('ru-RU') %></td>
                    <td><%= order.items_summary || '—' %></td>
                    <td><%= order.customer_type === 'student' ? 'Студент' : order.customer_type === 'teacher' ? 'Преподаватель' : 'Гость' %></td>
                    <td><%= order.total_quantity %></td>
                    <td><strong><%= Number(order.total_price || 0).toFixed(2) %> руб.</strong></td>
                    <td><%= order.staff_name || 'Не назначено' %></td>
                    <td>
                        <span class="status-badge <%= order.status === 'completed' ? 'status-active' : order.status === 'preparing' ? 'status-repair' : order.status === 'cancelled' ? 'status-inactive' : 'status-pending' %>">
                            <%= order.status === 'new' ? 'Новый' : order.status === 'preparing' ? 'Готовится' : order.status === 'completed' ? 'Выдан' : 'Отменен' %>
                        </span>
                    </td>
                    <td>
                        <div class="action-buttons">
                            <a href="/orders/edit/<%= order.id %>" class="btn btn-small btn-primary">✏️</a>
                            <a href="/orders/<%= order.id %>/receipt" class="btn btn-small btn-success" title="Скачать чек">🧾</a>
                            <form action="/orders/delete/<%= order.id %>" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-small btn-danger" onclick="return confirm('Удалить заказ?')">🗑️</button>
                            </form>
                            <form action="/orders/<%= order.id %>/status" method="POST" style="display:inline;">
                                <select name="status" class="status-select" onchange="this.form.submit()" title="Быстро сменить статус">
                                    <option value="new" <%= order.status === 'new' ? 'selected' : '' %>>Новый</option>
                                    <option value="preparing" <%= order.status === 'preparing' ? 'selected' : '' %>>Готовится</option>
                                    <option value="completed" <%= order.status === 'completed' ? 'selected' : '' %>>Выдан</option>
                                    <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Отменен</option>
                                </select>
                            </form>
                        </div>
                    </td>
                </tr>
            <% }) %>
            </tbody>
        </table>
    </div>
<% } else { %>
    <div class="empty-state"><p>Заказов пока нет</p></div>
<% } %>

<script>
    function toggleForm() {
        const form = document.getElementById('addForm');
        form.style.display = form.style.display === 'none' ? 'block' : 'none';
    }
</script>
<%- include('partials/footer') %>
