<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="header">
        <div class="container">
            <nav class="navbar">
                <a href="/" class="logo">📊 Учет ремонта</a>
                <ul class="nav-links">
                    <li><a href="/">Дашборд</a></li>
                    <li><a href="/equipment" class="active">Оборудование</a></li>
                    <li><a href="/repairs">Ремонты</a></li>
                    <li><a href="/employees">Сотрудники</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="main">
        <div class="container">
            <div class="page-header">
                <h1>Оборудование</h1>
                <button class="btn btn-primary" onclick="toggleForm()">+ Добавить оборудование</button>
            </div>

            <!-- Форма добавления -->
            <div id="addForm" class="form-container" style="display: none;">
                <h3>Добавить новое оборудование</h3>
                <form action="/equipment" method="POST">
                    <div class="form-group">
                        <label for="type_id">Тип оборудования:</label>
                        <select id="type_id" name="type_id" required>
                            <option value="">Выберите тип</option>
                            <% equipmentTypes.forEach(type => { %>
                                <option value="<%= type.id %>"><%= type.name %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="inventory_number">Инвентарный номер:</label>
                        <input type="text" id="inventory_number" name="inventory_number" required>
                    </div>
                    <div class="form-group">
                        <label for="name">Название:</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="model">Модель:</label>
                        <input type="text" id="model" name="model">
                    </div>
                    <div class="form-group">
                        <label for="purchase_date">Дата приобретения:</label>
                        <input type="date" id="purchase_date" name="purchase_date">
                    </div>
                    <div class="form-group">
                        <label for="location">Местонахождение:</label>
                        <input type="text" id="location" name="location">
                    </div>
                    <button type="submit" class="btn btn-primary">Добавить</button>
                    <button type="button" class="btn btn-secondary" onclick="toggleForm()">Отмена</button>
                </form>
            </div>

            <!-- Список оборудования -->
            <div class="equipment-list">
                <% if (equipment.length > 0) { %>
                    <div class="table-container">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Инв. номер</th>
                                    <th>Название</th>
                                    <th>Тип</th>
                                    <th>Модель</th>
                                    <th>Статус</th>
                                    <th>Местоположение</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% equipment.forEach(item => { %>
                                    <tr>
                                        <td><strong><%= item.inventory_number %></strong></td>
                                        <td><%= item.name %></td>
                                        <td><%= item.type_name %></td>
                                        <td><%= item.model %></td>
                                        <td>
                                            <span class="status-badge <%= item.status === 'active' ? 'status-active' : item.status === 'repair' ? 'status-repair' : 'status-inactive' %>">
                                                <%= item.status === 'active' ? 'Работает' : item.status === 'repair' ? 'В ремонте' : 'Неактивно' %>
                                            </span>
                                        </td>
                                        <td><%= item.location %></td>
                                        <td>
                                            <div class="action-buttons">
                                                <a href="/equipment/edit/<%= item.id %>" class="btn btn-small btn-primary">✏️</a>
                                                <form action="/equipment/delete/<%= item.id %>" method="POST" style="display: inline;">
                                                    <button type="submit" class="btn btn-small btn-danger" onclick="return confirm('Удалить это оборудование?')">🗑️</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state">
                        <p>Оборудование не найдено</p>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <p>&copy; 2024 Система учета ремонта оборудования</p>
        </div>
    </footer>

    <script>
        function toggleForm() {
            const form = document.getElementById('addForm');
            form.style.display = form.style.display === 'none' ? 'block' : 'none';
        }
    </script>
</body>
</html>